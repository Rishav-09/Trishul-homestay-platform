					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"bookings"
					]
				},
				"description": "Protected endpoint to fetch bookings. Attempting to query without a valid JWT token returns a 401 Unauthorized status."
			},
			"response": []
		},
